generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(uuid())
  name                  String?
  phone                 String?
  ageGroup              String?
  requiredTermsAgreed   Boolean   @default(false)
  requiredTermsAgreedAt DateTime?
  notificationAgreed    Boolean   @default(false)
  marketingAgreed       Boolean   @default(false)

  // 알림 설정 — 보안 알림
  alertSuspiciousLogin  Boolean   @default(true)
  alertPasswordChange   Boolean   @default(true)
  alertNewDevice        Boolean   @default(true)
  alertRecoveryEmail    Boolean   @default(true)

  // 알림 설정 — 마케팅
  alertSecurityTip      Boolean   @default(false)
  alertEventPromo       Boolean   @default(false)

  lastLoginAt           DateTime?
  createdAt             DateTime  @default(now())

  gmailAccounts  GmailAccount[]
  analysisRuns   AnalysisRun[]
  securityChat   SecurityChat?
  refreshTokens  AuthRefreshToken[]
}

/// 앱 로그인 refresh 토큰 (로테이션·즉시 폐기용). Gmail OAuth refreshToken 과 별개.
model AuthRefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model WithdrawalLog {
  id           String   @id @default(uuid())
  reason       String
  reasonDetail String?
  deletedAt    DateTime @default(now())

  @@index([reason, deletedAt])
}

model GmailAccount {
  id                  String    @id @default(uuid())
  userId              String
  email               String    @unique
  refreshToken        String
  isPrimary           Boolean   @default(false)
  label               String?
  status              String    @default("connected") // connected | reconnect_required
  lastSyncedAt        DateTime?
  lastEmailReceivedAt DateTime?
  createdAt           DateTime  @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccounts ServiceAccount[]
}

model AnalysisRun {
  id             String    @id @default(uuid())
  userId         String
  status         String    @default("queued") // queued | scanning | completed | failed
  mode           String    @default("initial") // initial | incremental | manual
  progress       Int       @default(0)
  currentStep    String    @default("waiting") // waiting | checking_connected_mail | collecting_account_signals | preparing_home | completed | failed
  displayMessage String?
  failedReason    String?
  reportSnapshot  Json?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccounts ServiceAccount[]

  @@index([userId, status])
  @@index([userId, startedAt])
}

model ServiceAccount {
  id              String    @id @default(uuid())
  gmailAccountId  String
  analysisRunId   String?
  aiAccountId     String?
  serviceName     String
  displayName     String?
  iconUrl         String?
  iconLabel       String?
  riskLevel       String    @default("safe") // high | medium | low | safe
  status          String    @default("safe") // action_required | watch | safe | resolved | skipped | dormant
  primaryRiskType String? // new_device_login | password_reset | verification_code | account_recovery | permission_grant | security_recommendation
  headline        String?
  summary         String?
  interpretation  String?
  resolvedAt      DateTime?
  skippedAt       DateTime?
  dormantAt       DateTime?
  previousStatus  String?
  lastAnalyzedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  gmailAccount    GmailAccount    @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)
  analysisRun     AnalysisRun?    @relation(fields: [analysisRunId], references: [id])
  riskEvidences   RiskEvidence[]
  actionItems     ActionItem[]
  actionSessions  ActionSession[]

  @@unique([gmailAccountId, serviceName])
  @@index([gmailAccountId, status])
  @@index([gmailAccountId, status, dormantAt])
}

model RiskEvidence {
  id               String    @id @default(uuid())
  serviceAccountId String
  riskType         String
  sender           String?
  subject          String?
  receivedAt       DateTime?
  summary          String?
  evidenceHash     String
  createdAt        DateTime  @default(now())

  serviceAccount ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@unique([serviceAccountId, evidenceHash])
}

model ActionItem {
  id               String   @id @default(uuid())
  serviceAccountId String
  type             String   @default("unknown") // KB stepType: change_password | enable_2fa | ...
  title            String
  description      String?
  why              String?
  isRequired       Boolean  @default(false)
  externalUrl      String?
  order            Int      @default(0)
  status           String   @default("pending") // pending | done | failed | skipped
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  serviceAccount ServiceAccount  @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  attempts       ActionAttempt[]

  @@index([serviceAccountId, status])
}

model ActionSession {
  id                  String    @id @default(uuid())
  serviceAccountId    String
  status              String    @default("active") // active | completed | abandoned
  activeActionItemId  String?
  feedbackEnabled     Boolean   @default(false)
  composerEnabled     Boolean   @default(false)
  composerPlaceholder String?
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt

  serviceAccount ServiceAccount  @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  messages       ActionMessage[]
  attempts       ActionAttempt[]

  @@index([serviceAccountId, status])
  // Partial unique: 서비스 계정당 active 세션 1개 — SQL migration에서 생성
  // CREATE UNIQUE INDEX "ActionSession_one_active_per_sa" ON "ActionSession"("serviceAccountId") WHERE status = 'active';
}

model ActionMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // assistant | user
  type      String   // text | risk_intro | action_list | user_chip | official_link | tip | card_news | feedback_actions | celebration | exit_cta
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session ActionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ActionAttempt {
  id             String   @id @default(uuid())
  sessionId      String
  actionItemId   String
  status         String   // completed | failed | skipped
  reason         String?
  reasonCategory String?  // cannot_find_page | login_failed | not_my_account | do_later | other
  createdAt      DateTime @default(now())

  session    ActionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actionItem ActionItem    @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
}

model SecurityChat {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SecurityChatMessage[]
}

model SecurityChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  role      String   // user | assistant
  type      String   // text | action_list | official_link | card_news | tip | exit_cta
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  chat SecurityChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model BetaApplicant {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String
  createdAt DateTime @default(now())
}

// IDly-apps-in-toss 서비스에서 사용하는 테이블 — 직접 수정 금지
model UserResponseLog {
  userId       String    @map("user_id")
  actionItemId String    @map("action_item_id")
  status       String
  createdAt    DateTime  @map("created_at")
  completedAt  DateTime? @map("completed_at")

  @@id([userId, actionItemId])
  @@map("user_response_logs")
}
