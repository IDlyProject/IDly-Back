generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(uuid())
  name                  String?
  phone                 String?
  ageGroup              String?
  requiredTermsAgreed   Boolean   @default(false)
  requiredTermsAgreedAt DateTime?
  notificationAgreed    Boolean   @default(false)
  marketingAgreed       Boolean   @default(false)
  createdAt             DateTime  @default(now())

  gmailAccounts GmailAccount[]
  analysisRuns  AnalysisRun[]
}

model GmailAccount {
  id                  String    @id @default(uuid())
  userId              String
  email               String    @unique
  refreshToken        String
  isPrimary           Boolean   @default(false)
  label               String?
  status              String    @default("connected") // connected | reconnect_required
  lastSyncedAt        DateTime?
  lastEmailReceivedAt DateTime?
  createdAt           DateTime  @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccounts ServiceAccount[]
}

model AnalysisRun {
  id             String    @id @default(uuid())
  userId         String
  status         String    @default("queued") // queued | scanning | completed | failed
  mode           String    @default("initial") // initial | incremental | manual
  progress       Int       @default(0)
  currentStep    String    @default("waiting") // waiting | checking_connected_mail | collecting_account_signals | preparing_home | completed | failed
  displayMessage String?
  failedReason   String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccounts ServiceAccount[]

  @@index([userId, status])
  @@index([userId, startedAt])
}

model ServiceAccount {
  id              String    @id @default(uuid())
  gmailAccountId  String
  analysisRunId   String?
  aiAccountId     String?
  serviceName     String
  displayName     String?
  iconUrl         String?
  iconLabel       String?
  riskLevel       String    @default("safe") // high | medium | low | safe
  status          String    @default("safe") // action_required | watch | safe | resolved | skipped | dormant
  primaryRiskType String? // new_device_login | password_reset | verification_code | account_recovery | permission_grant | security_recommendation
  headline        String?
  summary         String?
  interpretation  String?
  resolvedAt      DateTime?
  skippedAt       DateTime?
  lastAnalyzedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  gmailAccount  GmailAccount   @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)
  analysisRun   AnalysisRun?   @relation(fields: [analysisRunId], references: [id])
  riskEvidences RiskEvidence[]
  actionItems   ActionItem[]

  @@unique([gmailAccountId, serviceName])
  @@index([gmailAccountId, status])
}

model RiskEvidence {
  id               String    @id @default(uuid())
  serviceAccountId String
  riskType         String
  sender           String?
  subject          String?
  receivedAt       DateTime?
  summary          String?
  evidenceHash     String?
  createdAt        DateTime  @default(now())

  serviceAccount ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)

  @@unique([serviceAccountId, evidenceHash])
}

model ActionItem {
  id               String   @id @default(uuid())
  serviceAccountId String
  title            String
  description      String?
  isRequired       Boolean  @default(false)
  externalUrl      String?
  order            Int      @default(0)
  status           String   @default("pending") // pending | done | skipped
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  serviceAccount ServiceAccount @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
}

model BetaApplicant {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String
  createdAt DateTime @default(now())
}

// IDly-apps-in-toss 서비스에서 사용하는 테이블 — 직접 수정 금지
model UserResponseLog {
  userId       String    @map("user_id")
  actionItemId String    @map("action_item_id")
  status       String
  createdAt    DateTime  @map("created_at")
  completedAt  DateTime? @map("completed_at")

  @@id([userId, actionItemId])
  @@map("user_response_logs")
}
